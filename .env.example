# Foundry site — environment shape.
# Copy to .env.local for local development. Real values are set as Fly secrets in
# production (never committed). Access to /reports is checked server-side and
# fails closed: if the Supabase env is missing, no one is admitted.

# Supabase project (auth only; reports stay JSON files in reports/).
# From the project's API settings. The anon key is safe to expose to the client.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=

# Comma-separated emails that see ALL reports in the gated /reports collection
# (everyone else sees only reports whose meta.owner matches their sign-in email).
# Optional: if unset, no one has the admin view.
ADMIN_EMAILS=you@example.com

# Local sign-in also needs http://localhost:3000/auth/confirm in the Supabase
# project's redirect URL allowlist, or emailed magic links will not land.

# PostHog (optional; analytics no-ops everywhere when unset). The browser key
# is inlined at build time (in production it comes from fly.toml [build.args],
# not a secret; a phc key is public by design). The server falls back to the
# NEXT_PUBLIC value when POSTHOG_KEY is unset.
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_KEY=
